#!/usr/bin/env sh

# Block sensitive files from ever being committed
BLOCKED_PATTERNS=".cursorrules$|AGENTS\.md$|CLAUDE\.md$|\.env$|\.env\.local$|\.env\.prod$|\.env\.dev$|graphify-out/|\.opencode/|\.cursor/|\.claude/|\.superpowers/"
BLOCKED=$(git diff --cached --name-only --diff-filter=ACM | grep -E "$BLOCKED_PATTERNS" || true)
if [ -n "$BLOCKED" ]; then
  echo "BLOCKED: These files must not be committed to a public repo:"
  echo "$BLOCKED"
  echo ""
  echo "Remove them from staging: git reset HEAD <file>"
  exit 1
fi

echo "Running lint-staged (ESLint + Prettier)..."
npx lint-staged

echo "Running type check..."
npm run typecheck

echo "Running circular dependency check..."
npm run circular

echo "All pre-commit checks passed!"
