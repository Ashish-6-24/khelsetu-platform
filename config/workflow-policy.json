{
  "version": "1.0.0",
  "workflows": {
    "ci.yml": {
      "trigger": ["push", "pull_request"],
      "trusted": true,
      "required_for_merge": true,
      "jobs": {
        "fast_tier": [
          "lint",
          "format",
          "typecheck",
          "build",
          "unit-1",
          "unit-2",
          "coverage",
          "npm-audit",
          "codeql"
        ],
        "heavy_tier": ["e2e", "smoke", "a11y", "lighthouse"]
      }
    },
    "pr-review.yml": {
      "trigger": ["pull_request"],
      "trusted": true,
      "required_for_merge": false,
      "skip_actors": ["dependabot[bot]", "renovate[bot]"]
    },
    "diagnose.yml": {
      "trigger": ["workflow_run"],
      "trusted": true,
      "required_for_merge": false,
      "listens_to": ["CI"]
    },
    "auto-fix.yml": {
      "trigger": ["workflow_dispatch"],
      "trusted": false,
      "allowed_branches": ["master", "main", "develop"],
      "max_fixes_per_run": 1
    },
    "verify.yml": {
      "trigger": ["workflow_dispatch"],
      "trusted": false,
      "required_for_merge": true
    },
    "auto-merge.yml": {
      "trigger": ["pull_request"],
      "trusted": true,
      "required_for_merge": true,
      "auto_merge_actors": ["dependabot[bot]", "renovate[bot]", "Ashish-6-24"]
    },
    "security.yml": {
      "trigger": ["push", "pull_request", "schedule"],
      "trusted": true,
      "required_for_merge": true
    },
    "ai-qa.yml": {
      "trigger": ["schedule", "workflow_dispatch"],
      "trusted": true,
      "required_for_merge": false
    }
  },
  "merge_gating": {
    "required_workflows": ["ci.yml", "security.yml"],
    "optional_workflows": ["pr-review.yml", "ai-qa.yml"],
    "max_pending_reviews": 1,
    "owner_can_force_merge": true
  }
}
